# ---- Database ----
# Full SQLAlchemy connection string used by the app.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/logsentinel

# Postgres container credentials (used by the `db` service in docker-compose).
POSTGRES_DB=logsentinel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- Kafka ----
# Broker address. Local/compose default is kafka:9092.
# On Railway/cloud, point this at your managed broker (e.g. Upstash/Redpanda).
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=logs

# ---- LLM (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-5

# ---- Email alerts (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-app-password
ALERT_TO=oncall@example.com
ALERT_FROM=alerts@example.com

# ---- MCP server ----
# Base URL the MCP server uses to reach the FastAPI app.
API_BASE_URL=http://localhost:8000
# Transport: "stdio" for Claude Desktop / Cursor, "http" for the container service.
MCP_TRANSPORT=stdio
MCP_PORT=8001

# ---- Deployment ----
# Set automatically by Railway; used to detect prod vs local. Optional.
RAILWAY_ENVIRONMENT=
